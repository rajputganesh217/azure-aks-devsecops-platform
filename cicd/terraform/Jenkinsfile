pipeline {
agent any


options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '10'))
    timestamps()
    timeout(time: 1, unit: 'HOURS')
}

parameters {
    choice(name: 'ENVIRONMENT', choices: ['dev','qa','test','uat','prod'], description: 'Target deployment environment')
    choice(name: 'ACTION', choices: ['plan','apply','destroy'], description: 'Terraform action')
}

environment {

    TF_DIR = "infra/terraform/env/core"
    CONF_DIR = "backend"
    REPORTS_STORAGE = "devdevsecopsrepg0aa9"

    ARM_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
    ARM_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
    ARM_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
    ARM_TENANT_ID       = credentials('AZURE_TENANT_ID')

    TF_VAR_postgres_db       = credentials('POSTGRES_DB')
    TF_VAR_postgres_user     = credentials('POSTGRES_USER')
    TF_VAR_postgres_password = credentials('POSTGRES_PASSWORD')
    TF_VAR_jump_ssh_public_key = credentials('JUMP_SSH_PUBLIC_KEY')
}

stages {

    stage('Prepare Workspace') {
        steps {
            script { prepareWorkspace() }
        }
    }

/*
    stage('Security Scans') {

        parallel {

            stage('Checkov Scan') {
                steps { script { runCheckovScan() } }
            }

            stage('Gitleaks Scan') {
                steps { script { runGitleaksScan() } }
            }

        }

    }
*/

    stage('Terraform Init') {
        steps { script { terraformInit() } }
    }

    stage('Terraform Quality Checks') {

        parallel {

            stage('Terraform Format') {
                steps { script { terraformFmt() } }
            }

            stage('Terraform Validate') {
                steps { script { terraformValidate() } }
            }

        }

    }

    stage('Terraform Plan') {

        when {
            expression { params.ACTION != 'destroy' }
        }

        steps { script { terraformPlan() } }
    }

    stage('Approval Gate') {

        when {
            expression { params.ENVIRONMENT != 'dev' && params.ACTION == 'apply' }
        }

        steps {
            input message: "Approve deployment to ${params.ENVIRONMENT}?"
        }
    }

    stage('Terraform Execute') {
        steps { script { terraformExecute() } }
    }

/*
    stage('Upload Security Reports') {
        steps { script { uploadReports() } }
    }
*/

}

post {

    always {
        archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
        cleanWs()
    }

    success {
        echo "Terraform pipeline completed successfully"
    }

    failure {
        echo "Terraform pipeline failed"
    }
}


}

def prepareWorkspace() {


env.COMMIT_ID = sh(
    script: "git rev-parse --short=8 HEAD",
    returnStdout: true
).trim()

sh '''
rm -rf security-reports
mkdir -p security-reports
'''

echo "Workspace ready for commit ${env.COMMIT_ID}"


}

def runCheckovScan() {


sh """
checkov -d ${env.TF_DIR} \
  --framework terraform \
  --quiet \
  -o json \
  > security-reports/checkov-${params.ENVIRONMENT}.json || true
"""


}

def runGitleaksScan() {


sh """
gitleaks detect \
  --source . \
  --report-format json \
  --report-path security-reports/gitleaks.json || true
"""


}

def terraformInit() {


dir("${env.TF_DIR}") {

    sh """
    terraform init \
      -backend-config=${WORKSPACE}/${env.CONF_DIR}/${params.ENVIRONMENT}.conf \
      -reconfigure
    """
}


}

def terraformFmt() {


dir("${env.TF_DIR}") {

    sh "terraform fmt -check || true"
}


}

def terraformValidate() {


dir("${env.TF_DIR}") {

    sh "terraform validate"
}


}

def terraformPlan() {


dir("${env.TF_DIR}") {

    sh """
    terraform plan \
      -var-file=tfvars/${params.ENVIRONMENT}.tfvars \
      -var='commit_id=${env.COMMIT_ID}' \
      -out=tfplan-${params.ENVIRONMENT}.out
    """
}


}

def terraformExecute() {


dir("${env.TF_DIR}") {

    if (params.ACTION == 'apply') {

        sh """
        terraform apply \
          -auto-approve \
          tfplan-${params.ENVIRONMENT}.out
        """

    }

    else if (params.ACTION == 'destroy') {

        sh """
        terraform destroy \
          -auto-approve \
          -var-file=tfvars/${params.ENVIRONMENT}.tfvars \
          -var='commit_id=${env.COMMIT_ID}'
        """
    }
}


}

def uploadReports() {


sh """

az login --service-principal \
  -u $ARM_CLIENT_ID \
  -p $ARM_CLIENT_SECRET \
  --tenant $ARM_TENANT_ID

az account set --subscription $ARM_SUBSCRIPTION_ID

az storage blob upload-batch \
  --account-name ${REPORTS_STORAGE} \
  --destination security-reports \
  --destination-path terraform/${params.ENVIRONMENT}/${env.COMMIT_ID} \
  --source security-reports \
  --auth-mode login
"""


}
