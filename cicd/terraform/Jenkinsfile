pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'test', 'qa', 'prod'], description: 'Target Environment')
        string(name: 'TF_STATE_RG', defaultValue: 'aks-microservices-rg', description: 'Resource Group of TF State Storage Account')
        string(name: 'TF_STATE_SA', defaultValue: 'terraformstate', description: 'Storage Account for TF State')
        string(name: 'TF_STATE_CONTAINER', defaultValue: 'tfstate', description: 'Container for TF State')
    }

    environment {
        TF_DIR = "infra/terraform/env/core"

        // Azure Auth for Terraform Backend & Provider
        ARM_CLIENT_ID       = credentials('ARM_CLIENT_ID')
        ARM_CLIENT_SECRET   = credentials('ARM_CLIENT_SECRET')
        ARM_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        ARM_TENANT_ID       = credentials('AZURE_TENANT_ID')

        // Application Secrets passed to Terraform via env vars
        TF_VAR_postgres_db       = credentials('POSTGRES_DB')
        TF_VAR_postgres_user     = credentials('POSTGRES_USER')
        TF_VAR_postgres_password = credentials('POSTGRES_PASSWORD')
        TF_VAR_db_host           = credentials('DB_HOST')

        // Azure CLI credentials for blob upload
        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Gitleaks Scan') {
            steps {
                sh '''
                DATE=$(date +%Y%m%d_%H%M%S)

                gitleaks detect \
                --source . \
                --config security/configs/gitleaks.toml \
                --report-format json \
                --report-path security/reports/gitleaks/gitleaks_$DATE.json \
                || true
                '''
            }
        }

        stage('Checkov Scan') {
            steps {
                sh '''
                DATE=$(date +%Y%m%d_%H%M%S)

                checkov \
                -d infra/terraform \
                --config-file security/configs/checkov.yaml \
                -o json \
                > security/reports/checkov/checkov_$DATE.json \
                || true
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                script {
                    dir("${env.TF_DIR}") {
                        sh """
                        terraform init \\
                          -backend-config="resource_group_name=${params.TF_STATE_RG}" \\
                          -backend-config="storage_account_name=${params.TF_STATE_SA}" \\
                          -backend-config="container_name=${params.TF_STATE_CONTAINER}" \\
                          -backend-config="key=${params.ENVIRONMENT}.terraform.tfstate"
                        """
                    }
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                script {
                    dir("${env.TF_DIR}") {
                        sh "terraform validate"
                    }
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                script {
                    terraformCmd("plan")
                }
            }
        }

        stage('Choose Action') {
            steps {
                script {
                    def action = input(
                        message: 'Select Terraform Action',
                        parameters: [
                            choice(
                                name: 'ACTION',
                                choices: ['apply', 'destroy'],
                                description: 'Choose apply or destroy'
                            )
                        ]
                    )

                    if (action == 'apply') {
                        terraformCmd('apply -auto-approve')
                    } else {
                        terraformCmd('destroy -auto-approve')
                    }
                }
            }
        }

        stage('Upload Security Reports to Blob Storage') {
            steps {
                script {
                    dir("${env.TF_DIR}") {
                        try {
                            env.REPORTS_SA = sh(script: "terraform output -raw security_reports_storage_account", returnStdout: true).trim()
                            env.REPORTS_CONTAINER = sh(script: "terraform output -raw security_reports_container", returnStdout: true).trim()
                            
                            sh '''
                            az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                            az account set --subscription $AZURE_SUBSCRIPTION_ID
                            
                            echo "Uploading reports to $REPORTS_SA / $REPORTS_CONTAINER"
                            az storage blob upload-batch \\
                              --account-name $REPORTS_SA \\
                              --auth-mode login \\
                              -d $REPORTS_CONTAINER \\
                              -s ../../../../security/reports/ \\
                              --pattern "**/*.json"
                            '''
                        } catch (Exception e) {
                            echo "Skipping report upload (probably due to destroy action): ${e.message}"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'security/reports/**/*.json', fingerprint: true
        }
    }
}

def terraformCmd(cmd) {
    dir("${env.TF_DIR}") {
        sh "terraform ${cmd} -var-file=\"tfvars/${params.ENVIRONMENT}.tfvars\""
    }
}
