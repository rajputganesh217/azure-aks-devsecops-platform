def terraformCmd(cmd) {
dir("${env.TF_DIR}") {
sh "terraform ${cmd}"
}
}

pipeline {

```
agent any

environment {
    TF_DIR = "infra/terraform/env/dev"
}

stages {

    stage('Checkout Code') {
        steps {
            checkout scm
        }
    }

    stage('Prepare Security Folders') {
        steps {
            sh '''
            mkdir -p security/reports/gitleaks
            mkdir -p security/reports/checkov
            '''
        }
    }

    stage('Gitleaks Scan') {
        steps {
            sh '''
            gitleaks detect \
            --source . \
            --config security/configs/gitleaks.toml \
            --report-format json \
            --report-path security/reports/gitleaks/gitleaks-report.json
            '''
        }
    }

    stage('Checkov Scan') {
        steps {
            sh '''
            checkov -d infra/terraform \
            --config-file security/configs/checkov.yaml \
            -o json > security/reports/checkov/checkov-report.json
            '''
        }
    }

    stage('Terraform Init') {
        steps {
            script {
                terraformCmd('init')
            }
        }
    }

    stage('Terraform Plan') {
        steps {
            script {
                terraformCmd('plan')
            }
        }
    }

    stage('Choose Action') {
        steps {
            script {
                def action = input(
                    message: 'Select Terraform Action',
                    parameters: [
                        choice(
                            name: 'ACTION',
                            choices: ['apply', 'destroy'],
                            description: 'Choose apply or destroy'
                        )
                    ]
                )

                if (action == 'apply') {
                    terraformCmd('apply -auto-approve')
                } else {
                    terraformCmd('destroy -auto-approve')
                }
            }
        }
    }

}

post {
    always {
        archiveArtifacts artifacts: 'security/reports/**/*.json', fingerprint: true
    }
}
```

}
