pipeline {
    agent any

    environment {
        APP_NAME         = "worker"
        IMAGE_NAME       = "mydevopsacr123.azurecr.io/${APP_NAME}"
        DOCKER_CREDS_ID  = "azure-acr-credentials"
        SONAR_PROJECT_KEY = "worker-service"
        SONAR_SERVER_ID  = "sonarqube"
        APP_DIR          = "app/worker"
        
        // Azure credentials and target info
        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')
        AKS_RESOURCE_GROUP    = "aks-microservices-rg"
        AKS_CLUSTER_NAME      = "microservices-aks"
    }

    stages {
        stage('Gitleaks Scan') {
            steps {
                sh '''
                gitleaks detect --source . --config security/configs/gitleaks.toml --report-format json --report-path gitleaks-report.json || true
                '''
            }
        }

        stage('SonarQube Static Code Analysis') {
            steps {
                dir("${env.APP_DIR}") {
                    withSonarQubeEnv("${env.SONAR_SERVER_ID}") {
                        sh "/opt/sonar-scanner/bin/sonar-scanner -Dsonar.projectKey=${env.SONAR_PROJECT_KEY} -Dsonar.sources=."
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    // Fail the build if the SonarQube Quality Gate fails
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('OWASP Dependency-Check') {
            steps {
                dir("${env.APP_DIR}") {
                    dependencyCheck additionalArguments: '--scan . --format ALL', odcInstallation: 'Default'
                    dependencyCheckPublisher pattern: 'dependency-check-report.xml'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${env.APP_DIR}") {
                    script {
                        dockerImage = docker.build("${env.IMAGE_NAME}:${env.BUILD_NUMBER}")
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh """
                trivy image \\
                  --exit-code 1 \\
                  --severity HIGH,CRITICAL \\
                  --no-progress \\
                  ${env.IMAGE_NAME}:${env.BUILD_NUMBER}
                """
            }
        }

        stage('Docker Push to ACR') {
            steps {
                script {
                    docker.withRegistry("https://mydevopsacr123.azurecr.io", "${env.DOCKER_CREDS_ID}") {
                        dockerImage.push()
                        dockerImage.push("latest")
                    }
                }
            }
        }

        stage('Deploy to AKS') {
            steps {
                sh '''
                az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                az account set --subscription $AZURE_SUBSCRIPTION_ID
                az aks get-credentials --resource-group $AKS_RESOURCE_GROUP --name $AKS_CLUSTER_NAME --overwrite-existing
                
                kubectl apply -f kubernetes/worker-deployment.yaml
                
                kubectl set image deployment/worker worker=${IMAGE_NAME}:${BUILD_NUMBER}
                kubectl rollout status deployment/worker
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Worker deployment executed successfully!"
        }
        failure {
            echo "Pipeline failed. Please check the logs."
        }
    }
}
