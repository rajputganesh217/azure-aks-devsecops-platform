def dockerImage

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
    }

    environment {

        APP_NAME = "worker"
        APP_DIR  = "app/worker"

        ENV_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : '-' + params.ENVIRONMENT}"
        ACR_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : params.ENVIRONMENT}"

        IMAGE_NAME   = "mydevopsacr${ACR_SUFFIX}123.azurecr.io/${APP_NAME}"
        REGISTRY_URL = "https://mydevopsacr${ACR_SUFFIX}123.azurecr.io"

        DOCKER_CREDS_ID = "azure-acr-credentials"

        SONAR_PROJECT_KEY = "worker-service"
        SONAR_SERVER_ID   = "sonarqube"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP = "aks-microservices${ENV_SUFFIX}-rg"
        AKS_CLUSTER_NAME   = "microservices-aks${ENV_SUFFIX}"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Security Scans') {
            parallel {

                stage('Gitleaks Scan') {
                    steps {
                        sh '''
                        mkdir -p security-reports
                        gitleaks detect \
                          --source . \
                          --config security/configs/gitleaks.toml \
                          --report-format json \
                          --report-path security-reports/gitleaks-report.json || true
                        '''
                    }
                }

                stage('SonarQube Scan') {
                    steps {
                        dir("${APP_DIR}") {
                            withSonarQubeEnv("${SONAR_SERVER_ID}") {
                                sh """
                                /opt/sonar-scanner/bin/sonar-scanner \
                                  -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                                  -Dsonar.sources=. \
                                  -Dsonar.python.version=3 \
                                  -Dsonar.ws.timeout=600
                                """
                            }
                        }
                    }
                }

                stage('OWASP Dependency Check') {
                    steps {
                        dir("${APP_DIR}") {
                            sh '''
                            mkdir -p /var/lib/jenkins/dependency-check-data || true

                            /opt/dependency-check/bin/dependency-check.sh \
                              --project "${APP_NAME}" \
                              --scan . \
                              --format XML \
                              --data /var/lib/jenkins/dependency-check-data \
                              --out dependency-check-report.xml \
                              --nvdApiKey $NVD_API_KEY \
                              --nvdApiDelay 5000 || true
                            '''

                            dependencyCheckPublisher pattern: 'dependency-check-report.xml'
                        }
                    }
                }
            }
        }

        stage('Sonar Quality Gate') {
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    dockerImage = docker.build(
                        "${IMAGE_NAME}:${BUILD_NUMBER}",
                        "-f docker/${APP_NAME}/Dockerfile ."
                    )
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '''
                mkdir -p security-reports

                trivy image \
                  --severity HIGH,CRITICAL \
                  --exit-code 0 \
                  --no-progress \
                  --format table \
                  ${IMAGE_NAME}:${BUILD_NUMBER} \
                  > security-reports/trivy-report.txt || true
                '''
            }
        }

        stage('Push Image') {
            steps {
                script {
                    docker.withRegistry("${REGISTRY_URL}", "${DOCKER_CREDS_ID}") {
                        dockerImage.push()
                        dockerImage.push("latest")
                    }
                }
            }
        }

        stage('Deploy to AKS') {
            steps {
                sh '''
                az login --service-principal \
                  -u $AZURE_CLIENT_ID \
                  -p $AZURE_CLIENT_SECRET \
                  --tenant $AZURE_TENANT_ID

                az account set --subscription $AZURE_SUBSCRIPTION_ID

                az aks command invoke \
                  --resource-group $AKS_RESOURCE_GROUP \
                  --name $AKS_CLUSTER_NAME \
                  --file kubernetes/worker/worker-deployment.yaml \
                  --command "
                    kubectl apply -f worker-deployment.yaml;
                    kubectl set image deployment/worker worker=${IMAGE_NAME}:${BUILD_NUMBER};
                    kubectl rollout status deployment/worker
                  "
                '''
            }
        }

        stage('Upload Security Reports') {
            steps {
                sh '''
                tar -czvf security-reports/security-reports-${APP_NAME}-b${BUILD_NUMBER}.tar.gz security-reports/* || true
                '''
            }
        }
    }

    post {

        always {
            archiveArtifacts artifacts: 'security-reports/**', fingerprint: true
            cleanWs()
        }

        success {
            echo "Worker deployed successfully!"
        }

        failure {
            echo "Worker pipeline failed!"
        }
    }
}
