pipeline {
    agent any

    environment {

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP    = "aks-microservices-rg"
        AKS_CLUSTER_NAME      = "microservices-aks"

        POSTGRES_USER         = credentials('POSTGRES_USER')
        POSTGRES_PASSWORD     = credentials('POSTGRES_PASSWORD')
        POSTGRES_DB           = credentials('POSTGRES_DB')
    }

    stages {

        stage('Login to Azure') {
            steps {
                sh '''
                az login --service-principal \\
                -u $AZURE_CLIENT_ID \\
                -p $AZURE_CLIENT_SECRET \\
                --tenant $AZURE_TENANT_ID

                az account set --subscription $AZURE_SUBSCRIPTION_ID
                '''
            }
        }

        stage('Create Postgres Secret') {
            steps {
                sh '''
                az aks command invoke \\
                --resource-group $AKS_RESOURCE_GROUP \\
                --name $AKS_CLUSTER_NAME \\
                --command "
                kubectl delete secret postgres-secret --ignore-not-found;
                kubectl create secret generic postgres-secret \\
                --from-literal=POSTGRES_DB=$POSTGRES_DB \\
                --from-literal=POSTGRES_USER=$POSTGRES_USER \\
                --from-literal=POSTGRES_PASSWORD=$POSTGRES_PASSWORD
                "
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                # Pull the target database image locally to scan it
                docker pull postgres:15
                
                # Run Trivy against the official postgres image to detect vulnerabilities
                trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress --format table postgres:15
                trivy image --exit-code 0 --severity HIGH,CRITICAL --no-progress --format json -o trivy-report.json postgres:15
                '''
            }
        }

        stage('Deploy PostgreSQL') {
            steps {
                sh '''
                az aks command invoke \\
                --resource-group $AKS_RESOURCE_GROUP \\
                --name $AKS_CLUSTER_NAME \\
                --file kubernetes/postgres/postgres-deployment.yaml \\
                --file kubernetes/postgres/postgres-service.yaml \\
                --command "
                kubectl apply -f postgres-deployment.yaml;
                kubectl apply -f postgres-service.yaml;
                kubectl rollout status deployment/postgres
                "
                '''
            }
        }

        stage('Upload Security Reports to Azure Storage') {
            steps {
                sh '''
                az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                az account set --subscription $AZURE_SUBSCRIPTION_ID
                
                # Format the report and archive it exactly like the microservices
                mv trivy-report.json trivy-report-database.json
                tar -czvf security-reports-database-latest.tar.gz trivy-report-database.json
                
                # Ensure container exists and upload the report
                az storage container create --name security-reports --account-name tfstatedevsecops01 --auth-mode login || true
                az storage blob upload \\
                  --account-name tfstatedevsecops01 \\
                  --container-name security-reports \\
                  --name database/latest/security-reports-database-latest.tar.gz \\
                  --file security-reports-database-latest.tar.gz \\
                  --auth-mode login
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }

        success {
            echo "PostgreSQL deployed successfully!"
        }

        failure {
            echo "Database pipeline failed"
        }
    }
}
