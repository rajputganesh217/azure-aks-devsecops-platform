pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
        booleanParam(name: 'GENERATE_SECRET', defaultValue: false, description: 'Generate/Recreate Secrets (DB & TLS)?')
    }

    environment {
        K8S_DIR = "kubernetes/postgres"
        STORAGE_ACCOUNT = "${params.ENVIRONMENT}devsecopsrep"
        NAMESPACE = "${params.ENVIRONMENT}"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP = "aks-microservices-${params.ENVIRONMENT}-rg"
        AKS_CLUSTER_NAME   = "microservices-aks${params.ENVIRONMENT == 'dev' ? '' : '-' + params.ENVIRONMENT}"

        JUMP_SERVER_IP = credentials('JUMP_SERVER_IP')
        JUMP_USER      = "ganesh"

        POSTGRES_USER      = credentials('POSTGRES_USER')
        POSTGRES_PASSWORD  = credentials('POSTGRES_PASSWORD')
        POSTGRES_DB        = credentials('POSTGRES_DB')
    }

    stages {
        stage('Prepare') {
            steps {
                script {
                    env.COMMIT_ID = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()
                    sh "rm -rf security-reports && mkdir -p security-reports"
                }
            }
        }


        stage('Security: Manifest Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps {
                script {
                    sh "docker run --rm -v \$(pwd):/project zegl/kube-score:latest score ${K8S_DIR}/*.yaml > security-reports/kube-score-database.txt || true"
                }
            }
        }


        stage('Create Secret') {
            steps { script { createSecret() } }
        }

        stage('Security: Image Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { scanPostgres() } }
        }


        stage('Deploy PostgreSQL') {
            steps { script { deployPostgres() } }
        }

        stage('Upload Reports') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { uploadReports() } }
        }

    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
            cleanWs()
        }
    }
}


def createSecret() {
    withCredentials([sshUserPrivateKey(credentialsId: 'jump-server-ssh', keyFileVariable: 'SSH_KEY')]) {
        sh """
            set -e
            ssh-keygen -f "/var/lib/jenkins/.ssh/known_hosts" -R "${JUMP_SERVER_IP}" || true
            scp -o StrictHostKeyChecking=no -i ${SSH_KEY} ${K8S_DIR}/openssl.cnf ${JUMP_USER}@${JUMP_SERVER_IP}:/tmp/openssl-san.cnf

            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${JUMP_USER}@${JUMP_SERVER_IP} "
                set -e
                kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                
                # Let Secrets Store CSI driver manage postgres-secret from Key Vault.
                # Only creating TLS secret manually if required.
                
                # Create TLS secret (self-signed wildcard cert) for HTTPS
                if [ \"${params.GENERATE_SECRET}\" = \"true\" ] || ! kubectl get secret microservices-tls-secret -n ${NAMESPACE} > /dev/null 2>&1; then
                    echo \"Creating/Updating TLS secret in namespace ${NAMESPACE}...\"
                    
                    kubectl delete secret microservices-tls-secret -n ${NAMESPACE} --ignore-not-found
                    
                    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \\
                      -keyout /tmp/tls.key \\
                      -out /tmp/tls.crt \\
                      -config /tmp/openssl-san.cnf
                    
                    kubectl create secret tls microservices-tls-secret -n ${NAMESPACE} \\
                      --cert=/tmp/tls.crt --key=/tmp/tls.key
                    
                    echo \"TLS secret microservices-tls-secret created successfully.\"
                    rm -f /tmp/tls.key /tmp/tls.crt /tmp/openssl-san.cnf
                else
                    echo \"TLS secret microservices-tls-secret already exists. Skipping creation.\"
                fi
            "
        """
    }
}

def scanPostgres() {
    sh '''
    docker pull postgres:15
    trivy image --quiet --no-progress --timeout 15m \
      --severity HIGH,CRITICAL \
      --format json \
      -o security-reports/trivy-postgres.json \
      postgres:15 || true
    '''
}

def deployPostgres() {
    def remoteDir = "/tmp/k8s-postgres-${env.BUILD_NUMBER}"

    withCredentials([sshUserPrivateKey(credentialsId: 'jump-server-ssh', keyFileVariable: 'SSH_KEY')]) {
        sh """
            set -e
            
            az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
            az account set --subscription $AZURE_SUBSCRIPTION_ID
            
            # Fetch CSI Identity Client ID dynamically
            CSI_IDENTITY_CLIENT_ID=\$(az aks show -g ${AKS_RESOURCE_GROUP} -n ${AKS_CLUSTER_NAME} --query "addonProfiles.azureKeyvaultSecretsProvider.identity.clientId" -o tsv)
            export CSI_IDENTITY_CLIENT_ID
            echo "Fetched CSI_IDENTITY_CLIENT_ID: \$CSI_IDENTITY_CLIENT_ID"

            # Perform variable substitution locally on the Jenkins agent
            for f in ${K8S_DIR}/*.yaml; do
                envsubst '\$AZURE_TENANT_ID,\$CSI_IDENTITY_CLIENT_ID,\$NAMESPACE' < "\$f" > "\$f.tmp" && mv "\$f.tmp" "\$f"
            done

            ssh-keygen -f "/var/lib/jenkins/.ssh/known_hosts" -R "${JUMP_SERVER_IP}" || true
            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${JUMP_USER}@${JUMP_SERVER_IP} "mkdir -p ${remoteDir}"
            scp -o StrictHostKeyChecking=no -i ${SSH_KEY} ${K8S_DIR}/*.yaml ${JUMP_USER}@${JUMP_SERVER_IP}:${remoteDir}/

            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${JUMP_USER}@${JUMP_SERVER_IP} "
                set -e
                kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                kubectl apply -f ${remoteDir}/ -n ${NAMESPACE}
                kubectl rollout status deployment/postgres -n ${NAMESPACE} --timeout=300s
                rm -rf ${remoteDir}
            "
        """
    }
}

def uploadReports() {
    sh '''
    # Clear Azure CLI cache to avoid AttributeError issues
    rm -rf ~/.azure/msal_http_cache.bin || true

    az account set --subscription $AZURE_SUBSCRIPTION_ID

    ACCOUNT_KEY=$(az storage account keys list --account-name $STORAGE_ACCOUNT --query "[0].value" -o tsv)

    az storage blob upload-batch \
      --account-name $STORAGE_ACCOUNT \
      --account-key $ACCOUNT_KEY \
      --destination security-reports/database/$COMMIT_ID \
      --source security-reports \
      --auth-mode key || true
    '''
}
