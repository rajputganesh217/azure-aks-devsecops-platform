pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
        booleanParam(name: 'GENERATE_SECRET', defaultValue: false, description: 'Generate/Recreate Secrets (DB & TLS)?')
    }

    environment {
        K8S_DIR = "kubernetes/postgres"
        NAMESPACE = "${params.ENVIRONMENT}"

        ACR_NAME = "mydevopsacr123"
        AKS_RESOURCE_GROUP = "aks-microservices-dev-rg"
        AKS_CLUSTER_NAME = "microservices-aks"
        STORAGE_ACCOUNT = "devdevsecopsrep"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        // Terraform needs ARM_* env vars
        ARM_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        ARM_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        ARM_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        ARM_TENANT_ID       = credentials('AZURE_TENANT_ID')

        JUMP_USER      = "ganesh"

        POSTGRES_USER      = credentials('POSTGRES_USER')
        POSTGRES_PASSWORD  = credentials('POSTGRES_PASSWORD')
        POSTGRES_DB        = credentials('POSTGRES_DB')
    }

    stages {
        stage('Prepare') {
            steps {
                script {
                    env.COMMIT_ID = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()
                    sh "rm -rf security-reports && mkdir -p security-reports"

                    // Auto-fetch Jump Server IP from Terraform output
                    azLogin()
                    env.JUMP_SERVER_IP = fetchTerraformOutput("jump_server_ip")
                    echo "Jump Server IP: ${env.JUMP_SERVER_IP}"
                }
            }
        }

        stage('Security: Manifest Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps {
                script {
                    sh "docker run --rm -v \$(pwd):/apps alpine/helm sh -c 'cd /apps/kubernetes/charts/platform && helm dependency build >/dev/null 2>&1 && helm template .' | docker run --rm -i zegl/kube-score:latest score - > security-reports/kube-score-database.txt || true"
                }
            }
        }

        stage('Create Secret') {
            steps { script { createSecret() } }
        }

        stage('Security: Image Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { scanPostgres() } }
        }

        stage('Deploy PostgreSQL') {
            steps { script { deployPostgres() } }
        }

        stage('Setup ArgoCD') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { setupArgoCD() } }
        }

        stage('Upload Reports') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { uploadReports() } }
        }

    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
            cleanWs()
        }
    }
}

// ──────────────────────────────────────────────
// FUNCTIONS
// ──────────────────────────────────────────────

def azLogin() {
    sh """
        az login --service-principal -u ${env.AZURE_CLIENT_ID} -p ${env.AZURE_CLIENT_SECRET} --tenant ${env.AZURE_TENANT_ID}
        az account set --subscription ${env.AZURE_SUBSCRIPTION_ID}
    """
}

def fetchTerraformOutput(String outputName) {
    dir("infra/terraform/env/core") {
        sh """
        terraform init \
          -backend-config=${WORKSPACE}/backend/dev.conf \
          -reconfigure > /dev/null 2>&1
        """
        return sh(script: "terraform output -raw ${outputName}", returnStdout: true).trim()
    }
}

def createSecret() {
    withCredentials([sshUserPrivateKey(credentialsId: 'jump-server-ssh', keyFileVariable: 'SSH_KEY')]) {
        sh """
            set -e
            ssh-keygen -f "/var/lib/jenkins/.ssh/known_hosts" -R "${env.JUMP_SERVER_IP}" || true
            scp -o StrictHostKeyChecking=no -i ${SSH_KEY} scripts/security/openssl.cnf ${JUMP_USER}@${env.JUMP_SERVER_IP}:/tmp/openssl-san.cnf

            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${JUMP_USER}@${env.JUMP_SERVER_IP} "
                set -e
                kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                
                if [ \\"${params.GENERATE_SECRET}\\" = \\"true\\" ] || ! kubectl get secret microservices-tls-secret -n ${NAMESPACE} > /dev/null 2>&1; then
                    echo \\"Creating/Updating TLS secret in namespace ${NAMESPACE}...\\"
                    
                    kubectl delete secret microservices-tls-secret -n ${NAMESPACE} --ignore-not-found
                    
                    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \\\\
                      -keyout /tmp/tls.key \\\\
                      -out /tmp/tls.crt \\\\
                      -config /tmp/openssl-san.cnf
                    
                    kubectl create secret tls microservices-tls-secret -n ${NAMESPACE} \\\\
                      --cert=/tmp/tls.crt --key=/tmp/tls.key
                    
                    echo \\"TLS secret microservices-tls-secret created successfully.\\"
                    rm -f /tmp/tls.key /tmp/tls.crt /tmp/openssl-san.cnf
                else
                    echo \\"TLS secret microservices-tls-secret already exists. Skipping creation.\\"
                fi
            "
        """
    }
}

def scanPostgres() {
    sh '''
    docker pull postgres:15
    trivy image --quiet --no-progress --timeout 15m \
      --severity HIGH,CRITICAL \
      --format json \
      -o security-reports/trivy-postgres.json \
      postgres:15 || true
    '''
}

def deployPostgres() {
    def remoteDir = "/tmp/k8s-postgres-${env.BUILD_NUMBER}"

    sh """
        set -e
        export KEYVAULT_NAME="${params.ENVIRONMENT}-devsecops-kv"

        echo "Ensuring Key Vault \${KEYVAULT_NAME} exists..."
        KV_EXISTS=\$(az keyvault list -g ${env.AKS_RESOURCE_GROUP} --query "[?name=='\${KEYVAULT_NAME}'].name" -o tsv)
        if [ -z "\$KV_EXISTS" ]; then
            echo "Creating Key Vault \${KEYVAULT_NAME}..."
            az keyvault create --name \${KEYVAULT_NAME} -g ${env.AKS_RESOURCE_GROUP} --location eastus --enable-rbac-authorization true
            sleep 15
        fi
        
        KV_SCOPE=\$(az keyvault show -n \${KEYVAULT_NAME} --query "id" -o tsv)

        CSI_IDENTITY_CLIENT_ID=\$(az aks show -g ${env.AKS_RESOURCE_GROUP} -n ${env.AKS_CLUSTER_NAME} --query "addonProfiles.azureKeyvaultSecretsProvider.identity.clientId" -o tsv)
        echo "\$CSI_IDENTITY_CLIENT_ID" > csi_client_id.txt

        CSI_IDENTITY_OBJECT_ID=\$(az aks show -g ${env.AKS_RESOURCE_GROUP} -n ${env.AKS_CLUSTER_NAME} --query "addonProfiles.azureKeyvaultSecretsProvider.identity.objectId" -o tsv)

        echo "Assigning Roles..."
        az role assignment create --role "Key Vault Administrator" --assignee "${env.AZURE_CLIENT_ID}" --scope "\$KV_SCOPE" || true
        az role assignment create --role "Key Vault Secrets User" --assignee-object-id "\$CSI_IDENTITY_OBJECT_ID" --assignee-principal-type ServicePrincipal --scope "\$KV_SCOPE" || true

        echo "Populating Secrets in \${KEYVAULT_NAME} (waiting for RBAC propagation)..."
        for i in {1..6}; do
            set +e
            az keyvault secret set --vault-name "\${KEYVAULT_NAME}" --name "postgres-db" --value "\${POSTGRES_DB}" >/dev/null 2>&1
            RESULT=\$?
            set -e
            
            if [ \$RESULT -eq 0 ]; then
                az keyvault secret set --vault-name "\${KEYVAULT_NAME}" --name "postgres-user" --value "\${POSTGRES_USER}" >/dev/null
                az keyvault secret set --vault-name "\${KEYVAULT_NAME}" --name "postgres-password" --value "\${POSTGRES_PASSWORD}" >/dev/null
                echo "Secrets successfully populated! Waiting 60s for DB CSI..."
                sleep 60
                break
            else
                echo "Waiting 20s for Azure RBAC propagation... (Attempt \$i/6)"
                sleep 20
            fi
        done
    """
    
    env.CSI_IDENTITY_CLIENT_ID = sh(script: "cat csi_client_id.txt", returnStdout: true).trim()

    withCredentials([sshUserPrivateKey(credentialsId: 'jump-server-ssh', keyFileVariable: 'SSH_KEY')]) {
        sh """
            set -e
            export KEYVAULT_NAME="${params.ENVIRONMENT}-devsecops-kv"
            envsubst '\$AZURE_TENANT_ID,\$CSI_IDENTITY_CLIENT_ID,\$NAMESPACE,\$KEYVAULT_NAME' < kubernetes/network-policies.yaml > network-policies.yaml.tmp
            mv network-policies.yaml.tmp kubernetes/network-policies.yaml

            ssh-keygen -f "/var/lib/jenkins/.ssh/known_hosts" -R "${env.JUMP_SERVER_IP}" || true
            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${JUMP_USER}@${env.JUMP_SERVER_IP} "mkdir -p ${remoteDir}"
            scp -o StrictHostKeyChecking=no -i ${SSH_KEY} kubernetes/network-policies.yaml kubernetes/rbac.yaml ${JUMP_USER}@${env.JUMP_SERVER_IP}:${remoteDir}/

            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${JUMP_USER}@${env.JUMP_SERVER_IP} "
                set -e
                kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                kubectl apply -f ${remoteDir}/rbac.yaml -n ${NAMESPACE}
                kubectl apply -f ${remoteDir}/network-policies.yaml -n ${NAMESPACE}
                rm -rf ${remoteDir}
            "
        """
    }
}

def uploadReports() {
    sh """
    rm -rf ~/.azure/msal_http_cache.bin || true
    az account set --subscription ${env.AZURE_SUBSCRIPTION_ID}
    ACCOUNT_KEY=\$(az storage account keys list --account-name ${env.STORAGE_ACCOUNT} --query "[0].value" -o tsv)
    az storage blob upload-batch \\
      --account-name ${env.STORAGE_ACCOUNT} \\
      --account-key \$ACCOUNT_KEY \\
      --destination security-reports/database/${env.COMMIT_ID} \\
      --source security-reports \\
      --auth-mode key || true
    """
}

def setupArgoCD() {
    def remoteDir = "/tmp/argocd-setup-${env.BUILD_NUMBER}"

    withCredentials([sshUserPrivateKey(credentialsId: 'jump-server-ssh', keyFileVariable: 'SSH_KEY')]) {
        sh """
            set -e

            ssh-keygen -f "/var/lib/jenkins/.ssh/known_hosts" -R "${env.JUMP_SERVER_IP}" || true

            ssh -o StrictHostKeyChecking=no -i \${SSH_KEY} ${JUMP_USER}@${env.JUMP_SERVER_IP} "mkdir -p ${remoteDir}/argocd/templates ${remoteDir}/security"

            scp -o StrictHostKeyChecking=no -i \${SSH_KEY} \
                kubernetes/argocd/Chart.yaml \
                kubernetes/argocd/values.yaml \
                kubernetes/argocd/install-argocd.sh \
                kubernetes/argocd/values-dev.yaml \
                kubernetes/argocd/values-qa.yaml \
                kubernetes/argocd/values-uat.yaml \
                kubernetes/argocd/values-prod.yaml \
                ${JUMP_USER}@${env.JUMP_SERVER_IP}:${remoteDir}/argocd/

            scp -o StrictHostKeyChecking=no -i \${SSH_KEY} \
                kubernetes/argocd/templates/application.yaml \
                ${JUMP_USER}@${env.JUMP_SERVER_IP}:${remoteDir}/argocd/templates/

            scp -o StrictHostKeyChecking=no -i \${SSH_KEY} \
                scripts/security/install-runtime-security.sh \
                ${JUMP_USER}@${env.JUMP_SERVER_IP}:${remoteDir}/security/

            ssh -o StrictHostKeyChecking=no -i \${SSH_KEY} ${JUMP_USER}@${env.JUMP_SERVER_IP} "
                set -e
                export CSI_IDENTITY_CLIENT_ID='${env.CSI_IDENTITY_CLIENT_ID}'
                export AZURE_TENANT_ID='${env.AZURE_TENANT_ID}'
                chmod +x ${remoteDir}/argocd/install-argocd.sh ${remoteDir}/security/install-runtime-security.sh
                ${remoteDir}/argocd/install-argocd.sh ${NAMESPACE}
                ${remoteDir}/security/install-runtime-security.sh
                rm -rf ${remoteDir}
            "
        """
    }
    echo "ArgoCD monitoring dashboard is ready at https://argocd.microservices.local"
}
