def dockerImage

pipeline {
    agent any

    environment {
        APP_NAME          = "backend"
        IMAGE_NAME        = "mydevopsacr123.azurecr.io/${APP_NAME}"
        DOCKER_CREDS_ID   = "azure-acr-credentials"
        SONAR_PROJECT_KEY = "backend-service"
        SONAR_SERVER_ID   = "sonarqube"
        APP_DIR           = "app/backend"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')
        AKS_RESOURCE_GROUP    = "aks-microservices-rg"
        AKS_CLUSTER_NAME      = "microservices-aks"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Parallel Security Scans') {
            parallel {

                stage('Gitleaks Scan') {
                    steps {
                        runGitleaksScan()
                    }
                }

                stage('SonarQube Scan') {
                    steps {
                        runSonarScan()
                    }
                }

                stage('OWASP Dependency Check') {
                    steps {
                        runDependencyCheck()
                    }
                }
            }
        }

        stage('SonarQube Quality Gate') {
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Docker Build') {
            steps {
                buildDockerImage()
            }
        }

        stage('Trivy Image Scan') {
            steps {
                runTrivyScan()
            }
        }

        stage('Push Image to ACR') {
            steps {
                pushDockerImage()
            }
        }

        stage('Deploy to AKS') {
            steps {
                deployToAks()
            }
        }

        stage('Upload Security Reports') {
            steps {
                uploadSecurityReports()
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', fingerprint: true
            cleanWs()
        }

        success {
            echo "Backend deployed successfully!"
        }

        failure {
            echo "Pipeline failed. Check logs."
        }
    }
}

def runGitleaksScan() {
    sh '''
    mkdir -p security-reports
    gitleaks detect \
      --source . \
      --config security/configs/gitleaks.toml \
      --report-format json \
      --report-path security-reports/gitleaks-report.json || true
    '''
}

def runSonarScan() {
    dir("${env.APP_DIR}") {
        withSonarQubeEnv("${env.SONAR_SERVER_ID}") {
            sh """
            /opt/sonar-scanner/bin/sonar-scanner \
              -Dsonar.projectKey=${env.SONAR_PROJECT_KEY} \
              -Dsonar.sources=. \
              -Dsonar.python.version=3 \
              -Dsonar.ws.timeout=600
            """
        }
    }
}

def runDependencyCheck() {
    dir("${env.APP_DIR}") {
        sh """
        mkdir -p /var/lib/jenkins/dependency-check-data || true

        /opt/dependency-check/bin/dependency-check.sh \
          --project "${APP_NAME}" \
          --scan . \
          --format XML \
          --data /var/lib/jenkins/dependency-check-data \
          --out dependency-check-report.xml \
          --nvdApiKey ${env.NVD_API_KEY} \
          --nvdApiDelay 5000 || true
        """

        dependencyCheckPublisher pattern: 'dependency-check-report.xml'
    }
}

def buildDockerImage() {
    dockerImage = docker.build(
        "${env.IMAGE_NAME}:${env.BUILD_NUMBER}",
        "-f docker/${env.APP_NAME}/Dockerfile ."
    )
}

def runTrivyScan() {
    sh """
    mkdir -p security-reports

    trivy image \
      --severity HIGH,CRITICAL \
      --exit-code 0 \
      --no-progress \
      --format table \
      ${env.IMAGE_NAME}:${env.BUILD_NUMBER} \
      > security-reports/trivy-report.txt || true
    """
}

def pushDockerImage() {
    docker.withRegistry(
        "https://mydevopsacr123.azurecr.io",
        "${env.DOCKER_CREDS_ID}"
    ) {
        dockerImage.push()
        dockerImage.push("latest")
    }
}

def deployToAks() {
    sh '''
    az login --service-principal \
      -u $AZURE_CLIENT_ID \
      -p $AZURE_CLIENT_SECRET \
      --tenant $AZURE_TENANT_ID

    az account set --subscription $AZURE_SUBSCRIPTION_ID

    az aks command invoke \
      --resource-group $AKS_RESOURCE_GROUP \
      --name $AKS_CLUSTER_NAME \
      --file kubernetes/backend/backend-deployment.yaml \
      --file kubernetes/backend/backend-service.yaml \
      --command "
        kubectl apply -f backend-deployment.yaml;
        kubectl apply -f backend-service.yaml;
        kubectl set image deployment/shoe-backend backend=${IMAGE_NAME}:${BUILD_NUMBER};
        kubectl rollout status deployment/shoe-backend
      "
    '''
}

def uploadSecurityReports() {
    sh '''
    mkdir -p security-reports

    tar -czvf security-reports/security-reports-${APP_NAME}-b${BUILD_NUMBER}.tar.gz security-reports/* || true
    '''
}
