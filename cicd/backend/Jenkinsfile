def dockerImage = ''

pipeline {
    agent any

    environment {
        APP_NAME         = "backend"
        IMAGE_NAME       = "mydevopsacr123.azurecr.io/${APP_NAME}"
        DOCKER_CREDS_ID  = "azure-acr-credentials"
        SONAR_PROJECT_KEY = "backend-service"
        SONAR_SERVER_ID  = "sonarqube"
        APP_DIR          = "app/backend"
        
        // Azure credentials and target info
        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')
        AKS_RESOURCE_GROUP    = "aks-microservices-rg"
        AKS_CLUSTER_NAME      = "microservices-aks"
        NVD_API_KEY           = credentials('NVD_API_KEY')
    }

    stages {
        stage('Gitleaks Scan') {
            steps {
                sh '''
                gitleaks detect --source . --config security/configs/gitleaks.toml --report-format json --report-path gitleaks-report.json || true
                '''
            }
        }

        stage('SonarQube Static Code Analysis') {
            steps {
                dir("${env.APP_DIR}") {
                    withSonarQubeEnv("${env.SONAR_SERVER_ID}") {
                        sh "/opt/sonar-scanner/bin/sonar-scanner -Dsonar.projectKey=${env.SONAR_PROJECT_KEY} -Dsonar.sources=. -Dsonar.language=py"
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    // Continue the build even if the SonarQube Quality Gate fails
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dir("${env.APP_DIR}") {
                    withCredentials([string(credentialsId: 'NVD_API_KEY', variable: 'NVD_API_KEY')]) {
                        sh '''
                        mkdir -p /var/lib/jenkins/dependency-check-data || true
                        /opt/dependency-check/bin/dependency-check.sh \\
                          --project "${APP_NAME}" \\
                          --scan . \\
                          --format XML \\
                          --data /var/lib/jenkins/dependency-check-data \\
                          --out dependency-check-report.xml \\
                          --nvdApiKey $NVD_API_KEY \\
                          --nvdApiDelay 5000 || { echo "Dependency-Check encountered an error, continuing pipeline."; cat << 'EOF' > dependency-check-report.xml
<?xml version="1.0"?><analysis xmlns="https://jeremylong.github.io/DependencyCheck/dependency-check.3.1.xsd"><scanInfo></scanInfo><projectInfo><name>Failed Scan Default</name><reportDate>2023-01-01T00:00:00.000Z</reportDate><credits>This report contains no findings due to an NVD API update error.</credits></projectInfo><dependencies></dependencies></analysis>
EOF
}
                        '''
                        dependencyCheckPublisher pattern: 'dependency-check-report.xml'
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    dockerImage = docker.build("${env.IMAGE_NAME}:${env.BUILD_NUMBER}", "-f docker/${env.APP_NAME}/Dockerfile .")
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh """
                trivy image \\
                  --exit-code 0 \\
                  --severity HIGH,CRITICAL \\
                  --no-progress \\
                  --format table \\
                  ${env.IMAGE_NAME}:${env.BUILD_NUMBER} > trivy-report.txt || true
                """
            }
        }

        stage('Docker Push to ACR') {
            steps {
                script {
                    docker.withRegistry("https://mydevopsacr123.azurecr.io", "${env.DOCKER_CREDS_ID}") {
                        dockerImage.push()
                        dockerImage.push("latest")
                    }
                }
            }
        }

        stage('Deploy to AKS') {
            steps {
                sh '''
                az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                az account set --subscription $AZURE_SUBSCRIPTION_ID
                az aks get-credentials --resource-group $AKS_RESOURCE_GROUP --name $AKS_CLUSTER_NAME --overwrite-existing
                
                kubectl apply -f kubernetes/backend-deployment.yaml
                kubectl apply -f kubernetes/backend-service.yaml
                
                kubectl set image deployment/backend backend=${IMAGE_NAME}:${BUILD_NUMBER}
                kubectl rollout status deployment/backend
                '''
            }
        }
        
        stage('Upload Security Reports to Azure Storage') {
            steps {
                sh '''
                az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID
                az account set --subscription $AZURE_SUBSCRIPTION_ID
                
                # Zip all the generated reports (ignoring errors if a file is missing)
                zip -r security-reports-${APP_NAME}-b${BUILD_NUMBER}.zip gitleaks-report.json app/${APP_NAME}/dependency-check-report.xml trivy-report.txt || true
                
                # Upload to Blob Storage (ensure the container exists or create it)
                az storage container create --name security-reports --account-name tfstatedevsecops01 --auth-mode login || true
                az storage blob upload \\
                    --account-name tfstatedevsecops01 \\
                    --container-name security-reports \\
                    --name ${APP_NAME}/${BUILD_NUMBER}/security-reports.zip \\
                    --file security-reports-${APP_NAME}-b${BUILD_NUMBER}.zip \\
                    --auth-mode login || true
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Backend deployment executed successfully!"
        }
        failure {
            echo "Pipeline failed. Please check the logs."
        }
    }
}
