def dockerImage

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
        string(name: 'PROMOTE_COMMIT_ID', defaultValue: '', description: 'Commit ID to promote (required for qa/uat/prod)')
    }

    environment {
        APP_NAME = "backend"
        APP_DIR  = "app/${APP_NAME}"
        K8S_DIR  = "kubernetes/${APP_NAME}"
        DOCKER_CREDS_ID = "azure-acr-credentials"
        SONAR_PROJECT_KEY = "${APP_NAME}-service"
        SONAR_SERVER_ID   = "sonarqube"
        STORAGE_ACCOUNT = "devdevsecopsrepwzn1c"

        REGISTRY   = "mydevopsacr123.azurecr.io"
        IMAGE_NAME = "${REGISTRY}/${APP_NAME}"
        NAMESPACE  = "${params.ENVIRONMENT}"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP = "aks-microservices-dev-rg"
        AKS_CLUSTER_NAME   = "microservices-aks"

        JUMP_SERVER_IP = credentials('JUMP_SERVER_IP')
        JUMP_USER      = "ganesh"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {
        stage('Prepare') {
            steps { script { prepareWorkspace() } }
        }

        stage('Security Scans') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            parallel {
                stage('Gitleaks') {
                    steps { script { runGitleaksScan() } }
                }
                stage('Dependency Check') {
                    steps { script { runDependencyCheck() } }
                }
            }
        }

        stage('Security: Manifest Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps {
                script {
                    sh "docker run --rm -v \$(pwd):/project zegl/kube-score:latest score ${K8S_DIR}/*.yaml > security-reports/kube-score-${APP_NAME}.txt || true"
                }
            }
        }

        stage('Docker Build & Push') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { dockerBuildPush() } }
        }

        stage('Trivy Image Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { runTrivyScan() } }
        }


        stage('Promote Image') {
            when { expression { params.ENVIRONMENT != 'dev' } }
            steps { script { dockerPullTagPush() } }
        }

        stage('Deploy to AKS') {
            steps { script { deployToAKS() } }
        }

        stage('Upload Security Reports') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { script { uploadSecurityReports() } }
        }

    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
            cleanWs()
        }
        success { echo "${APP_NAME} [${params.ENVIRONMENT}] pipeline completed successfully." }
        failure { echo "${APP_NAME} [${params.ENVIRONMENT}] pipeline failed." }
    }
}

// ──────────────────────────────────────────────
// FUNCTIONS
// ──────────────────────────────────────────────

def prepareWorkspace() {
    env.COMMIT_ID = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()
    env.DEPLOY_COMMIT = (params.PROMOTE_COMMIT_ID && params.PROMOTE_COMMIT_ID.trim() != '') ? params.PROMOTE_COMMIT_ID : env.COMMIT_ID

    // New Tagging Format: service-env-hash
    env.IMAGE_TAG = "${env.IMAGE_NAME}:${env.APP_NAME}-${params.ENVIRONMENT}-${env.DEPLOY_COMMIT}"

    sh "rm -rf security-reports && mkdir -p security-reports"
    echo "Environment: ${params.ENVIRONMENT} | Commit: ${env.DEPLOY_COMMIT} | Image: ${env.IMAGE_TAG}"
}

def runGitleaksScan() {
    sh """
    gitleaks detect \\
      --source . \\
      --config security/configs/gitleaks.toml \\
      --report-format json \\
      --report-path security-reports/gitleaks-${APP_NAME}.json || true
    """
}

def runDependencyCheck() {
    dir("${APP_DIR}") {
        sh """
        /opt/dependency-check/bin/dependency-check.sh \\
          --project ${APP_NAME} \\
          --scan . \\
          --format JSON \\
          --out ../../security-reports \\
          --nvdApiKey ${NVD_API_KEY} \\
          --nvdApiDelay 5000 || true
        """
    }
}

def dockerBuildPush() {
    sh "docker build -t ${env.IMAGE_TAG} -f docker/${APP_NAME}/Dockerfile ."
    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker push ${env.IMAGE_TAG}"
    }
    sh "docker image rm ${env.IMAGE_TAG} || true"
    echo "Image pushed: ${env.IMAGE_TAG}"
}

def runTrivyScan() {
    sh """
    trivy image --quiet \\
      --severity HIGH,CRITICAL \\
      --format json \\
      -o security-reports/trivy-${APP_NAME}.json \\
      ${env.IMAGE_TAG} || true
    """
}

def dockerPullTagPush() {
    def sourceEnvMap = ['qa': 'dev', 'uat': 'qa', 'prod': 'uat']
    def sourceEnv = sourceEnvMap[params.ENVIRONMENT]
    
    // Pull from the source environment's tag
    def sourceTag = "${env.IMAGE_NAME}:${env.APP_NAME}-${sourceEnv}-${env.DEPLOY_COMMIT}"
    // Target tag for the current environment
    def targetTag = "${env.IMAGE_TAG}"

    echo "Promoting ${sourceTag} → ${targetTag}"

    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker pull ${sourceTag}"
        sh "docker tag ${sourceTag} ${targetTag}"
        sh "docker push ${targetTag}"
    }
    sh "docker image rm ${sourceTag} ${targetTag} || true"
}

def deployToAKS() {
    def remoteDir = "/tmp/k8s-${APP_NAME}-${env.BUILD_NUMBER}"
    def dnsHost = "api-${NAMESPACE}.microservices.local"

    withCredentials([sshUserPrivateKey(credentialsId: 'jump-server-ssh', keyFileVariable: 'SSH_KEY')]) {
        // Replace placeholders in manifests
        sh """
        sed -i 's|{{IMAGE_TAG}}|${env.IMAGE_TAG}|g' ${K8S_DIR}/${APP_NAME}-deployment.yaml
        sed -i 's|{{HOSTNAME}}|${dnsHost}|g' ${K8S_DIR}/${APP_NAME}-ingress.yaml
        """

        // Copy manifests to Jump Server and deploy
        sh """
        ssh -o StrictHostKeyChecking=no -i \${SSH_KEY} ${JUMP_USER}@${JUMP_SERVER_IP} "mkdir -p ${remoteDir}"
        scp -o StrictHostKeyChecking=no -i \${SSH_KEY} ${K8S_DIR}/*.yaml ${JUMP_USER}@${JUMP_SERVER_IP}:${remoteDir}/

        ssh -o StrictHostKeyChecking=no -i \${SSH_KEY} ${JUMP_USER}@${JUMP_SERVER_IP} "
            kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
            kubectl apply -f ${remoteDir}/ -n ${NAMESPACE}
            kubectl rollout status deployment/shoe-backend -n ${NAMESPACE} --timeout=300s
            rm -rf ${remoteDir}
        "
        """
    }
    echo "Deployed ${APP_NAME} to ${params.ENVIRONMENT} namespace"
}

def uploadSecurityReports() {
    sh """
    # Clear Azure CLI cache to avoid AttributeError issues
    rm -rf ~/.azure/msal_http_cache.bin || true

    az storage blob upload-batch \\
      --account-name ${STORAGE_ACCOUNT} \\
      --destination security-reports \\
      --destination-path ${APP_NAME}/${env.COMMIT_ID} \\
      --source security-reports \\
      --auth-mode login || true
    """
}
