def dockerImage

pipeline {

    agent any
    
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
    }


    environment {

        APP_NAME = "backend"
        APP_DIR  = "app/backend"

        DOCKER_CREDS_ID = "azure-acr-credentials"

        SONAR_PROJECT_KEY = "backend-service"
        SONAR_SERVER_ID   = "sonarqube"

        STORAGE_ACCOUNT = "devdevsecopsrepg0aa9"

        ENV_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : '-' + params.ENVIRONMENT}"
        ACR_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : params.ENVIRONMENT}"

        REGISTRY   = "mydevopsacr${ACR_SUFFIX}123.azurecr.io"
        IMAGE_NAME = "${REGISTRY}/${APP_NAME}"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP = "aks-microservices${ENV_SUFFIX}-rg"
        AKS_CLUSTER_NAME   = "microservices-aks${ENV_SUFFIX}"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {

        stage('Prepare') {
            steps {
                script {
                    prepareWorkspace()
                }
            }
        }

        stage('Security Scans') {
            parallel {

                stage('Gitleaks') {
                    steps {
                        script { runGitleaksScan() }
                    }
                }

                // stage('SonarQube') {
                //     steps {
                //         script { runSonarScan() }
                //     }
                // }

                stage('Dependency Check') {
                    steps {
                        script { runDependencyCheck() }
                    }
                }

            }
        }

        stage('Security: Manifest Scan') {
            steps {
                script {
                    sh "docker run --rm -v \$(pwd):/project zegl/kube-score:latest score kubernetes/backend/*.yaml > security-reports/kube-score-backend.txt || true"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script { buildDockerImage() }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                script { runTrivyScan() }
            }
        }

        stage('Push Image to ACR') {
            steps {
                script { pushDockerImage() }
            }
        }

        stage('Deploy to AKS') {
            steps {
                script { deployToAKS() }
            }
        }

        stage('Upload Security Reports') {
            steps {
                script { uploadSecurityReports() }
            }
        }

    }

    post {

        always {
            archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
            cleanWs()
        }

        success {
            echo "Pipeline completed successfully."
        }

        failure {
            echo "Pipeline failed."
        }
    }
}






def prepareWorkspace() {
    env.COMMIT_ID = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()
    sh "rm -rf security-reports && mkdir -p security-reports"
}






def runGitleaksScan() {

    sh """
    gitleaks detect \
      --source . \
      --config security/configs/gitleaks.toml \
      --report-format json \
      --report-path security-reports/gitleaks-${APP_NAME}.json || true
    """
}






def runSonarScan() {

    dir("${APP_DIR}") {

        withSonarQubeEnv("${SONAR_SERVER_ID}") {

            sh """
            /opt/sonar-scanner/bin/sonar-scanner \
              -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
              -Dsonar.sources=. \
              -Dsonar.ws.timeout=600
            """

        }

    }
}






def runDependencyCheck() {

    dir("${APP_DIR}") {

        sh """
        /opt/dependency-check/bin/dependency-check.sh \
          --project ${APP_NAME} \
          --scan . \
          --format JSON \
          --out ../../security-reports \
          --nvdApiKey ${NVD_API_KEY} \
          --nvdApiDelay 5000 || true
        """
    }
}






def buildDockerImage() {
    sh "docker build -t ${IMAGE_NAME}:${APP_NAME}-${env.COMMIT_ID} -f docker/${APP_NAME}/Dockerfile ."
}






def runTrivyScan() {
    sh """
    trivy image --quiet \
      --severity HIGH,CRITICAL \
      --format json \
      -o security-reports/trivy-${APP_NAME}.json \
      ${IMAGE_NAME}:${APP_NAME}-${env.COMMIT_ID} || true
    """
}






def pushDockerImage() {
    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker push ${IMAGE_NAME}:${APP_NAME}-${env.COMMIT_ID}"
    }
}






def deployToAKS() {

    sh """

    az login --service-principal \
      -u $AZURE_CLIENT_ID \
      -p $AZURE_CLIENT_SECRET \
      --tenant $AZURE_TENANT_ID

    az account set --subscription $AZURE_SUBSCRIPTION_ID

    sh """
        # Dynamically update the image tag in the deployment manifest
        sed -i "s|image:.*|image: ${IMAGE_NAME}:${APP_NAME}-${env.COMMIT_ID}|g" kubernetes/backend/backend-deployment.yaml
    """

    az aks command invoke \
      --resource-group $AKS_RESOURCE_GROUP \
      --name $AKS_CLUSTER_NAME \
      --file kubernetes/backend/backend-deployment.yaml \
      --file kubernetes/backend/backend-service.yaml \
      --command "
        kubectl apply -f backend-deployment.yaml;
        kubectl apply -f backend-service.yaml;
        kubectl rollout status deployment/shoe-backend --timeout=300s
      " || true
    """
}






def uploadSecurityReports() {

    sh """

    az storage blob upload-batch \
      --account-name ${STORAGE_ACCOUNT} \
      --destination security-reports \
      --destination-path ${APP_NAME}/${env.COMMIT_ID} \
      --source security-reports \
      --auth-mode login

    """
}