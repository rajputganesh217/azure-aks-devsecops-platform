def dockerImage

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
    }

    environment {
        APP_NAME = "frontend"
        APP_DIR  = "app/frontend"
        STORAGE_ACCOUNT = "devdevsecopsrepg0aa9"
        DOCKER_CREDS_ID = "azure-acr-credentials"

        // Environment Suffix Logic
        ENV_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : '-' + params.ENVIRONMENT}"
        ACR_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : params.ENVIRONMENT}"

        REGISTRY   = "mydevopsacr${ACR_SUFFIX}123.azurecr.io"
        IMAGE_NAME = "${REGISTRY}/${APP_NAME}"

        // Azure Service Principal Credentials
        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP = "aks-microservices${ENV_SUFFIX}-rg"
        AKS_CLUSTER_NAME   = "microservices-aks${ENV_SUFFIX}"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {
        stage('Prepare') {
            steps { script { prepareWorkspace() } }
        }

        stage('Security Scans') {
            parallel {
                stage('Gitleaks Scan') {
                    steps { script { runGitleaksScan() } }
                }
                stage('Dependency Check') {
                    steps { script { runDependencyCheck() } }
                }
            }
        }

        stage('Security: Manifest Scan') {
            steps {
                script {
                    sh "docker run --rm -v \$(pwd):/project zegl/kube-score:latest score kubernetes/frontend/*.yaml > security-reports/kube-score-frontend.txt || true"
                }
            }
        }

        stage('Docker Build') {
            steps { script { buildDockerImage() } }
        }

        stage('Trivy Image Scan') {
            steps { script { runTrivyScan() } }
        }

        stage('Push Image to ACR') {
            steps { script { pushDockerImage() } }
        }

        stage('Deploy to AKS') {
            steps { script { deployFrontend() } }
        }

        stage('Upload Security Reports') {
            steps { script { uploadSecurityReports() } }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
            cleanWs()
        }
        success {
            echo "Frontend deployment successful!"
        }
        failure {
            echo "Frontend pipeline failed!"
        }
    }
}

// --- Logic Functions ---

def prepareWorkspace() {
    env.COMMIT_ID = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()
    sh "rm -rf security-reports && mkdir -p security-reports"
    
    // Log in once at the start
    sh """
        az login --service-principal -u ${AZURE_CLIENT_ID} -p ${AZURE_CLIENT_SECRET} --tenant ${AZURE_TENANT_ID}
        az account set --subscription ${AZURE_SUBSCRIPTION_ID}
    """
}

def runGitleaksScan() {
    sh "gitleaks detect --source . --config security/configs/gitleaks.toml --report-format json --report-path security-reports/gitleaks-${APP_NAME}.json || true"
}

def runDependencyCheck() {
    dir("${APP_DIR}") {
        sh """
            /opt/dependency-check/bin/dependency-check.sh \
              --project frontend --scan . --format JSON --out ../../security-reports \
              --nvdApiKey ${NVD_API_KEY} --nvdApiDelay 5000 || true
        """
    }
}

def buildDockerImage() {
    sh "docker build -t ${IMAGE_NAME}:frontend-${env.COMMIT_ID} -f docker/frontend/Dockerfile ."
}

def runTrivyScan() {
    sh "trivy image --quiet --no-progress --timeout 15m --format json -o security-reports/trivy-${APP_NAME}.json ${IMAGE_NAME}:frontend-${env.COMMIT_ID} || true"
}

def pushDockerImage() {
    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker push ${IMAGE_NAME}:frontend-${env.COMMIT_ID}"
    }
}

def deployFrontend() {
    // FIX: Combined shell logic to avoid nested blocks and used | delimiter for sed
    sh """
        # Update image tag
        sed -i "s|image:.*|image: ${IMAGE_NAME}:frontend-${env.COMMIT_ID}|g" kubernetes/frontend/deployment.yaml

        # Invoke all frontend manifests at once
        az aks command invoke \
          --resource-group ${AKS_RESOURCE_GROUP} \
          --name ${AKS_CLUSTER_NAME} \
          --file kubernetes/frontend/deployment.yaml \
          --file kubernetes/frontend/service.yaml \
          --file kubernetes/frontend/ingress.yaml \
          --command "kubectl apply -f deployment.yaml && kubectl apply -f service.yaml && kubectl apply -f ingress.yaml && kubectl rollout status deployment/shoe-frontend --timeout=300s"
    """
}

def uploadSecurityReports() {
    sh """
        az storage blob upload-batch \
          --account-name ${STORAGE_ACCOUNT} \
          --destination security-reports \
          --destination-path ${APP_NAME}/${env.COMMIT_ID} \
          --source security-reports \
          --auth-mode login
    """
}
