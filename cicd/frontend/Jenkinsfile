def dockerImage
def commitId

pipeline {

    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
    }

    environment {

        APP_NAME = "frontend"
        APP_DIR  = "app/frontend"

        ENV_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : '-' + params.ENVIRONMENT}"
        ACR_SUFFIX = "${params.ENVIRONMENT == 'dev' ? '' : params.ENVIRONMENT}"

        REGISTRY = "mydevopsacr${ACR_SUFFIX}123.azurecr.io"
        IMAGE_NAME = "${REGISTRY}/${APP_NAME}"

        STORAGE_ACCOUNT = "devdevsecopsrepg0aa9"

        DOCKER_CREDS_ID = "azure-acr-credentials"

        SONAR_PROJECT_KEY = "frontend-service"
        SONAR_SERVER_ID   = "sonarqube"

        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        AKS_RESOURCE_GROUP = "aks-microservices${ENV_SUFFIX}-rg"
        AKS_CLUSTER_NAME   = "microservices-aks${ENV_SUFFIX}"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {

        stage('Prepare') {
            steps { script { prepareWorkspace() } }
        }

        stage('Security Scans') {
            parallel {

                stage('Gitleaks') { steps { script { runGitleaksScan() } } }

                stage('SonarQube') { steps { script { runSonarScan() } } }

                stage('Dependency Check') { steps { script { runDependencyCheck() } } }

            }
        }

        stage('Docker Build') {
            steps { script { buildDockerImage() } }
        }

        stage('Trivy Scan') {
            steps { script { runTrivyScan() } }
        }

        stage('Push Image') {
            steps { script { pushDockerImage() } }
        }

        stage('Deploy to AKS') {
            steps { script { deployFrontend() } }
        }

        stage('Upload Reports') {
            steps { script { uploadSecurityReports() } }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', fingerprint: true
            cleanWs()
        }
    }
}





def prepareWorkspace() {

    commitId = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()

    sh "mkdir -p security-reports"
}





def runGitleaksScan() {

    sh """
    gitleaks detect \
    --source . \
    --config security/configs/gitleaks.toml \
    --report-format json \
    --report-path security-reports/gitleaks-${APP_NAME}.json || true
    """
}





def runSonarScan() {

    dir("${APP_DIR}") {

        withSonarQubeEnv("${SONAR_SERVER_ID}") {

            sh """
            /opt/sonar-scanner/bin/sonar-scanner \
            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
            -Dsonar.sources=. \
            -Dsonar.ws.timeout=600
            """
        }
    }
}





def runDependencyCheck() {

    dir("${APP_DIR}") {

        sh """
        /opt/dependency-check/bin/dependency-check.sh \
        --project ${APP_NAME} \
        --scan . \
        --format JSON \
        --out ../../security-reports \
        --nvdApiKey ${NVD_API_KEY} \
        --nvdApiDelay 5000 || true
        """
    }
}





def buildDockerImage() {

    dockerImage = docker.build(
        "${IMAGE_NAME}:${APP_NAME}-${commitId}",
        "-f docker/frontend/Dockerfile ."
    )
}





def runTrivyScan() {

    sh """
    trivy image \
    --severity HIGH,CRITICAL \
    --format json \
    -o security-reports/trivy-${APP_NAME}.json \
    ${IMAGE_NAME}:${APP_NAME}-${commitId}
    """
}





def pushDockerImage() {

    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {

        dockerImage.push("${APP_NAME}-${commitId}")
        dockerImage.push("latest")

    }
}





def deployFrontend() {

    sh """

    az login --service-principal \
    -u $AZURE_CLIENT_ID \
    -p $AZURE_CLIENT_SECRET \
    --tenant $AZURE_TENANT_ID

    az account set --subscription $AZURE_SUBSCRIPTION_ID

    az aks command invoke \
    --resource-group $AKS_RESOURCE_GROUP \
    --name $AKS_CLUSTER_NAME \
    --file kubernetes/frontend/deployment.yaml \
    --file kubernetes/frontend/service.yaml \
    --file kubernetes/frontend/ingress.yaml \
    --command "

    kubectl apply -f deployment.yaml;
    kubectl apply -f service.yaml;
    kubectl apply -f ingress.yaml;

    kubectl set image deployment/shoe-frontend \
    frontend=${IMAGE_NAME}:${APP_NAME}-${commitId};

    kubectl rollout status deployment/shoe-frontend

    "
    """
}





def uploadSecurityReports() {

    sh """

    az storage blob upload-batch \
    --account-name ${STORAGE_ACCOUNT} \
    --destination security-reports/${APP_NAME} \
    --source security-reports \
    --auth-mode login

    """
}