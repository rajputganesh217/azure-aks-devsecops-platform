def dockerImage

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev','qa','uat','prod'], description: 'Target Environment')
    }

    environment {
        APP_NAME = "frontend"
        APP_DIR  = "app/${APP_NAME}"
        K8S_DIR  = "kubernetes/${APP_NAME}"
        STORAGE_ACCOUNT = "devdevsecopsrepg0aa9"
        DOCKER_CREDS_ID = "azure-acr-credentials"

        
        REGISTRY   = "mydevopsacr123.azurecr.io"
        IMAGE_NAME = "${REGISTRY}/${APP_NAME}"
        NAMESPACE  = "${params.ENVIRONMENT}"

        // Source environment for image promotion (qa←dev, uat←qa, prod←uat)
        SOURCE_ENV = "${params.ENVIRONMENT == 'qa' ? 'dev' : (params.ENVIRONMENT == 'uat' ? 'qa' : (params.ENVIRONMENT == 'prod' ? 'uat' : ''))}"

        /
        AZURE_CLIENT_ID       = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET   = credentials('AZURE_CLIENT_SECRET')
        AZURE_SUBSCRIPTION_ID = credentials('AZURE_SUBSCRIPTION_ID')
        AZURE_TENANT_ID       = credentials('AZURE_TENANT_ID')

        
        AKS_RESOURCE_GROUP = "aks-microservices-rg"
        AKS_CLUSTER_NAME   = "microservices-aks"

        NVD_API_KEY = credentials('NVD_API_KEY')
    }

    stages {
        stage('Prepare') {
            steps { 
                script { 
                    prepareWorkspace() 
                } 
            }
        }

        stage('Security Scans') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            parallel {
                stage('Gitleaks Scan') {
                    steps { script { runGitleaksScan() } }
                }
                stage('Dependency Check') {
                    steps { script { runDependencyCheck() } }
                }
            }
        }

        stage('Security: Manifest Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps {
                script {
                    sh "docker run --rm -v \$(pwd):/project zegl/kube-score:latest score ${K8S_DIR}/*.yaml > security-reports/kube-score-${APP_NAME}.txt || true"
                }
            }
        }

        stage('Docker Build') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { 
                script { 
                    buildDockerImage() 
                } 
            }
        }

        stage('Trivy Image Scan') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { 
                script { 
                    runTrivyScan() 
                } 
            }
        }

        stage('Push Image to ACR') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { 
                script { 
                    pushDockerImage() 
                } 
            }
        }

        stage('Promote Image') {
            when { expression { params.ENVIRONMENT != 'dev' } }
            steps {
                script {
                    promoteImage()
                }
            }
        }

        stage('Deploy to AKS') {
            steps { 
                script { 
                    deployToAKS() 
                } 
            }
        }

        stage('Upload Security Reports') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps { 
                script { 
                    uploadSecurityReports() 
                } 
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'security-reports/**', allowEmptyArchive: true
            cleanWs()
        }
        success {
            echo "${APP_NAME} [${params.ENVIRONMENT}] deployment successful!"
        }
        failure {
            echo "${APP_NAME} [${params.ENVIRONMENT}] pipeline failed!"
        }
    }
}

// --- Logic Functions ---

def prepareWorkspace() {
    def commitId = sh(script: "git rev-parse --short=8 HEAD", returnStdout: true).trim()
    env.COMMIT_ID = commitId
    // Tag format: <env>-<commit> e.g. dev-abc12345, qa-abc12345
    env.IMAGE_TAG = "${params.ENVIRONMENT}-${commitId}"
    // Source tag for promotion (e.g. when deploying to qa, source is dev-<commit>)
    env.SOURCE_IMAGE_TAG = "${SOURCE_ENV}-${commitId}"
    
    sh "rm -rf security-reports && mkdir -p security-reports"
    
    sh """
        az login --service-principal -u ${AZURE_CLIENT_ID} -p ${AZURE_CLIENT_SECRET} --tenant ${AZURE_TENANT_ID}
        az account set --subscription ${AZURE_SUBSCRIPTION_ID}
    """
}

def runGitleaksScan() {
    sh "gitleaks detect --source . --config security/configs/gitleaks.toml --report-format json --report-path security-reports/gitleaks-${APP_NAME}.json || true"
}

def runDependencyCheck() {
    dir("${APP_DIR}") {
        sh """
            /opt/dependency-check/bin/dependency-check.sh \
              --project ${APP_NAME} --scan . --format JSON --out ../../security-reports \
              --nvdApiKey ${NVD_API_KEY} --nvdApiDelay 5000 || true
        """
    }
}

def buildDockerImage() {
    sh "docker build -t ${IMAGE_NAME}:${env.IMAGE_TAG} -f docker/${APP_NAME}/Dockerfile ."
}

def runTrivyScan() {
    sh "trivy image --quiet --no-progress --timeout 15m --format json -o security-reports/trivy-${APP_NAME}.json ${IMAGE_NAME}:${env.IMAGE_TAG} || true"
}

def pushDockerImage() {
    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker push ${IMAGE_NAME}:${env.IMAGE_TAG}"
    }
}

def promoteImage() {
    // Pull the image from the previous environment's tag, re-tag for this environment, push
    def sourceImage = "${IMAGE_NAME}:${env.SOURCE_IMAGE_TAG}"
    def targetImage = "${IMAGE_NAME}:${env.IMAGE_TAG}"

    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker pull ${sourceImage}"
    }

    sh "docker tag ${sourceImage} ${targetImage}"

    docker.withRegistry("https://${REGISTRY}", "${DOCKER_CREDS_ID}") {
        sh "docker push ${targetImage}"
    }
}

def deployToAKS() {
    sh """
       
        sed -i "s|image:.*|image: ${IMAGE_NAME}:${env.IMAGE_TAG}|g" ${K8S_DIR}/deployment.yaml

        
        FILE_ARGS=\$(ls ${K8S_DIR}/*.yaml | sed 's/^/--file /' | tr '\\n' ' ')

        az aks command invoke \
          --resource-group ${AKS_RESOURCE_GROUP} \
          --name ${AKS_CLUSTER_NAME} \
          \${FILE_ARGS} \
          --command "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f - && kubectl apply -f . -n ${NAMESPACE} && kubectl rollout status deployment/shoe-${APP_NAME} -n ${NAMESPACE} --timeout=300s"
    """
}

def uploadSecurityReports() {
    sh """
        az storage blob upload-batch \
          --account-name ${STORAGE_ACCOUNT} \
          --destination security-reports \
          --destination-path ${APP_NAME}/${env.COMMIT_ID} \
          --source security-reports \
          --auth-mode login
    """
}
